DATABASE_URL=postgresql://melodarr:melodarr@db:5432/melodarr?schema=public
REDIS_URL=redis://redis:6379
# Optional bootstrap value. App URL can be changed from Admin Settings.
APP_URL=http://localhost:3000
# Optional: override generated runtime secret.
# If omitted, Melodarr generates and stores one on first run.
SESSION_SECRET=

# Optional bootstrap defaults (can also be set in Admin > Settings)
JELLYFIN_URL=http://jellyfin:8096
JELLYFIN_API_KEY=
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=
LIDARR_ROOT_FOLDER=/music
LIDARR_QUALITY_PROFILE_ID=1
LIDARR_METADATA_PROFILE_ID=1
LIDARR_MONITOR_MODE=all
REQUEST_AUTO_APPROVE=true
