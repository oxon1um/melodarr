# Environment variables for local development
# Copy this file to .env.local and customize as needed when running `npm run dev`
#
# Required: Generate a secure secret with: openssl rand -hex 64
SESSION_SECRET=

# Local app process -> Docker Postgres/Redis published from docker-compose.local.yml
DATABASE_URL=postgresql://melodarr:melodarr@localhost:5432/melodarr?schema=public
REDIS_URL=redis://localhost:6379

# App URL - defaults to localhost, change in Admin Settings after setup
# APP_URL=http://localhost:30000

# Jellyfin/Lidarr configuration - set in Admin Settings after initial setup
# These can also be configured via environment variables:
# JELLYFIN_URL=http://jellyfin:8096
# JELLYFIN_API_KEY=
# LIDARR_URL=http://lidarr:8686
# LIDARR_API_KEY=
# LIDARR_ROOT_FOLDER=/music
# LIDARR_QUALITY_PROFILE_ID=1
# LIDARR_METADATA_PROFILE_ID=1
# LIDARR_MONITOR_MODE=all
# REQUEST_AUTO_APPROVE=true
